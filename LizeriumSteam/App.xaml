<Application
    x:Class="LizeriumSteam.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:LizeriumSteam.Converters"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:views="clr-namespace:LizeriumSteam.Views"
    xmlns:vm="clr-namespace:LizeriumSteam.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:ThemeResources />
                <hc:Theme />
            </ResourceDictionary.MergedDictionaries>
            <converters:LanguageToDisplayConverter x:Key="LanguageToDisplayConverter" />
            <converters:LanguageEqualityToBoolConverter x:Key="LanguageEqualityToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

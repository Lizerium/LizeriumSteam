<UserControl
    x:Class="LizeriumSteam.Views.GameButtonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel>
        <Border
            Height="300"
            MinWidth="260"
            MinHeight="135"
            MaxWidth="540"
            Padding="5"
            ClipToBounds="True"
            CornerRadius="12"
            Effect="{DynamicResource EffectShadow5}">
            <Grid>
                <hc:TransitioningContentControl TransitionStoryboard="{StaticResource FadeTransition}">
                    <!--  Фоновое изображение игры  -->
                    <Border
                        BorderBrush="#9A9A9A"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="12">
                        <Grid Effect="{DynamicResource EffectShadow5}">
                            <hc:TransitioningContentControl>
                                <hc:Carousel
                                    Height="376"
                                    MaxWidth="668"
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    AutoRun="True"
                                    Interval="00:00:07"
                                    IsCenter="True"
                                    IsManipulationEnabled="True">

                                    <Image
                                        MaxWidth="668"
                                        Source="{Binding ImageSourceImage1}"
                                        Stretch="UniformToFill" />
                                    <Image
                                        MaxWidth="668"
                                        Source="{Binding ImageSourceImage2}"
                                        Stretch="UniformToFill" />
                                    <Image
                                        MaxWidth="668"
                                        Source="{Binding ImageSourceImage3}"
                                        Stretch="UniformToFill" />
                                    <Image
                                        MaxWidth="668"
                                        Source="{Binding ImageSourceImage4}"
                                        Stretch="UniformToFill" />
                                </hc:Carousel>
                            </hc:TransitioningContentControl>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="100" />
                                    <RowDefinition Height="150" />
                                </Grid.RowDefinitions>
                                <hc:TransitioningContentControl TransitionStoryboard="{StaticResource FadeTransition}">
                                    <Border
                                        Height="100"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        CornerRadius="12"
                                        Effect="{StaticResource EffectShadow5}"
                                        Style="{StaticResource BorderRegion}"
                                        TextBlock.FontSize="20"
                                        Visibility="{Binding UpdateState}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Offset="0.65" Color="Black" />
                                                <GradientStop Offset="1" Color="#11000000" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <hc:Badge
                                                Height="30"
                                                BadgeMargin="0,-14,-20,0"
                                                Style="{StaticResource BadgeDanger}"
                                                Text="{Binding NewVersionToServer}">
                                                <TextBlock
                                                    x:Name="AvailableUpdateText"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    hc:IconElement.Geometry="{DynamicResource AddGeometry}"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding NeedUpdateStateText}" />
                                            </hc:Badge>

                                            <Button
                                                Grid.Column="1"
                                                Margin="0,50,30,0"
                                                hc:IconElement.Geometry="{DynamicResource AudioGeometry}"
                                                hc:IconElement.Width="30"
                                                Command="{Binding UpdateCommand}"
                                                Content="{DynamicResource GameViewUpdateGameText}"
                                                Cursor="Hand"
                                                Visibility="{Binding VisibleBtnDownload}" />
                                            <Button
                                                Grid.Column="1"
                                                Margin="0,50,30,0"
                                                hc:IconElement.Geometry="{DynamicResource RemoveGeometry}"
                                                hc:IconElement.Width="30"
                                                Command="{Binding StopUpdateCommand}"
                                                Content="{DynamicResource GameViewStopUpdateGameText}"
                                                Cursor="Hand"
                                                Visibility="{Binding VisibleDownload}" />
                                        </Grid>
                                    </Border>
                                </hc:TransitioningContentControl>
                                <hc:TransitioningContentControl
                                    Grid.Row="1"
                                    TransitionStoryboard="{StaticResource FadeTransition}"
                                    Visibility="{Binding VisibleDownload}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Height="120"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            CornerRadius="12"
                                            Effect="{StaticResource EffectShadow5}"
                                            Style="{StaticResource BorderRegion}"
                                            TextBlock.FontSize="20"
                                            Visibility="{Binding UpdateState}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Offset="0.0" Color="#11000000" />
                                                    <GradientStop Offset="1" Color="Black" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid Width="220">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <hc:Badge
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeWarning}"
                                                    Text="{Binding FileDownloadQueue}"
                                                    Visibility="{Binding IsDownloadFirstProcess}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource DownloadGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewQueueFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Grid.Row="1"
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeSuccess}"
                                                    Text="{Binding FileDownloadAll}"
                                                    Visibility="{Binding IsDownloadFirstProcess}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource ScrollModeGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewAllFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeInfo}"
                                                    Text="{Binding FileUnpackQueue}"
                                                    Visibility="{Binding IsUnpackFiles}">
                                                    <Button
                                                        Width="160"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource AudioGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewUnpackFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeDanger}"
                                                    Text="{Binding FileDeleteQueue}"
                                                    Visibility="{Binding IsDeleteFiles}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource DeleteFillCircleGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewDelFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Grid.Row="1"
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeSuccess}"
                                                    Text="{Binding FileDownloadAll}"
                                                    Visibility="{Binding IsDeleteFiles}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource ScrollModeGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewAllFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgePrimary}"
                                                    Text="{Binding DirsDeleteQueue}"
                                                    Visibility="{Binding IsDeleteDirs}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource DeleteGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewDelFilesText}" />
                                                </hc:Badge>
                                                <hc:Badge
                                                    Grid.Row="1"
                                                    Height="50"
                                                    BadgeMargin="0,5,-30,0"
                                                    Style="{StaticResource BadgeSuccess}"
                                                    Text="{Binding FileDownloadAll}"
                                                    Visibility="{Binding IsDeleteDirs}">
                                                    <Button
                                                        Width="150"
                                                        HorizontalContentAlignment="Left"
                                                        hc:IconElement.Geometry="{DynamicResource ScrollModeGeometry}"
                                                        hc:IconElement.Width="50"
                                                        Content="{DynamicResource GameViewAllFilesText}" />
                                                </hc:Badge>
                                            </Grid>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Height="120"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            CornerRadius="12"
                                            Effect="{StaticResource EffectShadow5}"
                                            Style="{StaticResource BorderRegion}"
                                            TextBlock.FontSize="20"
                                            Visibility="{Binding UpdateState}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Offset="0.00" Color="#11000000" />
                                                    <GradientStop Offset="1" Color="Black" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <hc:CircleProgressBar
                                                Width="70"
                                                Height="70"
                                                Margin="16,0,0,0"
                                                Style="{StaticResource ProgressBarDangerCircle}"
                                                Value="{Binding ProgressUpdateValue}" />
                                        </Border>
                                    </Grid>
                                </hc:TransitioningContentControl>
                            </Grid>
                            <!--  Плашка "Игра запущена"  -->
                            <hc:TransitioningContentControl TransitionStoryboard="{StaticResource FadeTransition}">
                                <Border
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    CornerRadius="12"
                                    Style="{StaticResource BorderRegion}"
                                    Visibility="{Binding InGameState}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Offset="0.45" Color="Black" />
                                            <GradientStop Offset="1" Color="#11000000" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{DynamicResource InGameStateText}" />
                                </Border>
                            </hc:TransitioningContentControl>

                            <!--  Плашка "Название игры"  -->
                            <hc:TransitioningContentControl TransitionStoryboard="{StaticResource FadeTransition}">
                                <Border
                                    Height="50"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="12"
                                    Visibility="Visible">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#11000000" />
                                            <GradientStop Offset="0.55" Color="#111" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </hc:TransitioningContentControl>

                            <!--  Затеняющий/размывающий слой при IsPanelVisible  -->
                            <Border
                                Background="#88000000"
                                CornerRadius="12"
                                Visibility="{Binding IsPanelVisible}">
                                <Border.Effect>
                                    <BlurEffect Radius="10" />
                                </Border.Effect>
                            </Border>

                            <!--  Кнопка меню  -->
                            <hc:TransitioningContentControl TransitionMode="Bottom2Top">
                                <!--  Верхние кнопки Changes/Settings  -->
                                <StackPanel
                                    Margin="5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal"
                                    ToolTip="{DynamicResource GameViewOpenMenuText}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0">
                                    <Button
                                        Name="ButtonConfig"
                                        Grid.Column="1"
                                        hc:IconElement.Geometry="{StaticResource AlignHStretchGeometry}"
                                        Click="ButtonConfig_Click"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Style="{StaticResource ButtonIcon}"
                                        Visibility="{Binding AvailableLeftMenu}">

                                        <Button.ContextMenu>
                                            <ContextMenu
                                                Closed="ContextMenu_Closed"
                                                DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                Opened="ContextMenu_Opened">
                                                <!--  Родительский пункт  -->
                                                <MenuItem Header="{DynamicResource GameViewMenuItemChangeLangText}" Visibility="{Binding AvailableLangs}">
                                                    <!--  Подменю: языки  -->
                                                    <MenuItem.ItemsSource>
                                                        <Binding Path="AvailableLanguages" />
                                                    </MenuItem.ItemsSource>

                                                    <MenuItem.ItemTemplate>
                                                        <DataTemplate>
                                                            <MenuItem
                                                                Command="{Binding DataContext.ChangeLangGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                CommandParameter="{Binding}"
                                                                Header="{Binding Converter={StaticResource LanguageToDisplayConverter}}">
                                                                <MenuItem.IsEnabled>
                                                                    <MultiBinding Converter="{StaticResource LanguageEqualityToBoolConverter}">
                                                                        <Binding Path="DataContext.SelectedLanguage" RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                        <Binding />
                                                                        <!--  текущий язык пункта меню  -->
                                                                    </MultiBinding>
                                                                </MenuItem.IsEnabled>
                                                            </MenuItem>
                                                        </DataTemplate>
                                                    </MenuItem.ItemTemplate>
                                                </MenuItem>
                                                <MenuItem
                                                    Command="{Binding OpenProjectUpdatesCommand}"
                                                    Header="Список обновлений"
                                                    Visibility="{Binding AvailableListChanges}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>

                                </StackPanel>
                            </hc:TransitioningContentControl>
                            <hc:TransitioningContentControl TransitionMode="Bottom2Top">
                                <!--  Нижняя кнопка левая меню запасного расширенные кнопки для скачивания обновления запуска  -->
                                <StackPanel
                                    Margin="5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal"
                                    ToolTip="{DynamicResource GameViewOpenControlBtnsText}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0">
                                    <Button
                                        Name="ButtonAllMenu"
                                        hc:IconElement.Geometry="{StaticResource AllGeometry}"
                                        Command="{Binding OpenBtnsMenuCommand}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Style="{StaticResource ButtonIcon}" />
                                </StackPanel>
                            </hc:TransitioningContentControl>
                            <hc:TransitioningContentControl TransitionMode="Bottom2Top">
                                <!--  Нижняя кнопка права меню запасного расширенные кнопки для скачивания обновления запуска  -->
                                <StackPanel
                                    Margin="5"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal">
                                    <Button
                                        Name="ButtonStopDownloadUpdate"
                                        hc:IconElement.Geometry="{StaticResource RemoveGeometry}"
                                        Command="{Binding StopUpdateCommand}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Style="{StaticResource ButtonIcon}"
                                        ToolTip="{DynamicResource GameViewStopUpdateGameText}"
                                        ToolTipService.BetweenShowDelay="0"
                                        ToolTipService.InitialShowDelay="0"
                                        Visibility="{Binding VisibleDownload}" />
                                    <Button
                                        Name="ButtonDownloadUpdate"
                                        hc:IconElement.Geometry="{StaticResource AudioGeometry}"
                                        Command="{Binding UpdateCommand}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Style="{StaticResource ButtonIcon}"
                                        ToolTip="{DynamicResource GameViewUpdateGameText}"
                                        ToolTipService.BetweenShowDelay="0"
                                        ToolTipService.InitialShowDelay="0"
                                        Visibility="{Binding IsMiniVisibleBtnDownload}" />
                                </StackPanel>
                            </hc:TransitioningContentControl>
                            <hc:TransitioningContentControl TransitionMode="Bottom2Top">
                                <!--  Верхняя кнопка права меню запасного расширенные кнопки для скачивания игры  -->
                                <StackPanel
                                    Margin="5"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal"
                                    ToolTip="{DynamicResource GameViewInstallGameText}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0">
                                    <Button
                                        Name="ButtonDownloadGame"
                                        hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                                        Command="{Binding InstallCommand}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        IsEnabled="{Binding DownloadStateMenu}"
                                        Style="{StaticResource ButtonIcon}"
                                        Visibility="{Binding DownloadState}" />
                                </StackPanel>
                            </hc:TransitioningContentControl>
                            <hc:TransitioningContentControl TransitionMode="Bottom2Top">
                                <!--  Верхняя кнопка центральная для запуска игры  -->
                                <StackPanel
                                    Margin="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Orientation="Horizontal"
                                    ToolTip="{DynamicResource GameViewStartGameText}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0">
                                    <Button
                                        Name="ButtonStartGame"
                                        hc:IconElement.Geometry="{StaticResource WindowsGeometry}"
                                        Command="{Binding StartGameCommand}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Style="{StaticResource ButtonIcon}"
                                        Visibility="{Binding StartGameState}" />
                                </StackPanel>
                            </hc:TransitioningContentControl>
                        </Grid>
                    </Border>
                </hc:TransitioningContentControl>

                <!--  Тайтл под карточкой  -->
                <hc:TransitioningContentControl TransitionStoryboard="{StaticResource FadeTransition}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="Azure"
                            Text="{Binding TitleView}" />
                        <hc:Badge
                            Margin="5,0,0,0"
                            VerticalAlignment="Top"
                            Status="Text"
                            Style="{StaticResource BadgePrimary}"
                            Text="{Binding LastVersion}" />
                    </StackPanel>
                </hc:TransitioningContentControl>

                <hc:TransitioningContentControl TransitionStoryboard="{StaticResource Top2BottomTransition}" Visibility="{Binding IsPanelVisible}">
                    <Border
                        Grid.Column="1"
                        Margin="40"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        CornerRadius="12"
                        Effect="{StaticResource EffectShadow5}"
                        Style="{StaticResource BorderRegion}"
                        TextBlock.FontSize="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="1" Color="Black" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid
                            x:Name="GameBtns"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Row="0"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource WindowsGeometry}"
                                Command="{Binding StartGameCommand}"
                                Content="{DynamicResource GameViewStartGameText}"
                                Cursor="Hand"
                                IsEnabled="{Binding MenuStartGameState}"
                                Style="{StaticResource ButtonInfo}"
                                TextOptions.TextFormattingMode="Ideal" />
                            <Button
                                Grid.Row="1"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource StarGeometry}"
                                Command="{Binding ForceStartGameCommand}"
                                Content="{DynamicResource GameViewForceStartGameText}"
                                Cursor="Hand"
                                IsEnabled="{Binding InGameStateMenu}"
                                Style="{StaticResource ButtonDanger}"
                                TextOptions.TextFormattingMode="Ideal" />
                            <Button
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource DropperGeometry}"
                                Command="{Binding InGameCommand}"
                                Content="{DynamicResource GameViewInGameText}"
                                Cursor="Hand"
                                IsEnabled="{Binding InGameStateMenu}"
                                Style="{StaticResource ButtonInfo}"
                                TextOptions.TextFormattingMode="Ideal" />
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource SaveGeometry}"
                                Command="{Binding InstallCommand}"
                                Content="{DynamicResource GameViewInstallGameText}"
                                Cursor="Hand"
                                IsEnabled="{Binding DownloadStateMenu}"
                                Style="{StaticResource ButtonSuccess}"
                                TextOptions.TextFormattingMode="Ideal" />
                            <Button
                                Grid.Row="2"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource AudioGeometry}"
                                Command="{Binding UpdateCommand}"
                                Content="{DynamicResource GameViewUpdateGameText}"
                                Cursor="Hand"
                                IsEnabled="{Binding UpdateStateMenu}"
                                Style="{StaticResource ButtonWarning}"
                                TextOptions.TextFormattingMode="Ideal" />
                            <Button
                                Grid.Row="2"
                                Margin="10,0,10,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                hc:IconElement.Geometry="{DynamicResource RemoveGeometry}"
                                Command="{Binding StopUpdateCommand}"
                                Content="{DynamicResource GameViewStopUpdateGameText}"
                                Cursor="Hand"
                                Style="{StaticResource ButtonWarning}"
                                TextOptions.TextFormattingMode="Ideal"
                                Visibility="{Binding VisibleDownload}" />
                        </Grid>
                    </Border>
                </hc:TransitioningContentControl>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
